graph TB
    subgraph ANTENNA["Antenna System"]
        OMNI["Omni Dipole\n2.4 GHz | 2 dBi\n360° Coverage"]
        YAGI["Yagi Directional\n2.4 GHz | 12 dBi\n~35° Beamwidth"]
    end

    subgraph MOTION["Motion Control System"]
        SPS["SPS-500 Positioner\n(Honeywell)\nAz: 0-360° continuous\nEl: -15° to +90°\nResolution: 0.01°"]
        RS422["RS-422 Interface\n115200 bps\nCRC-8 Checksums"]
        ENCODER["Encoder Feedback\nReal-time Position\n(Az + El)"]
        YAGI --- SPS
        SPS --- ENCODER
    end

    subgraph RF["RF Front End"]
        BPF_A["BPF + LNA\n2.4 GHz\n~20 dB gain\n<1.5 dB NF"]
        BPF_B["BPF + LNA\n2.4 GHz\n~20 dB gain\n<1.5 dB NF"]
    end

    subgraph SDR["USRP B210 (USB 3.0)"]
        RXA["RX-A (Omni)\n30.72 MSPS\n30 MHz BW"]
        RXB["RX-B (Yagi)\n30.72 MSPS\n30 MHz BW"]
    end

    subgraph HOST["Host Computer (Linux / Python)"]
        subgraph DSP["DSP Pipeline (asyncio)"]
            OMNI_PATH["Omni Path:\nIQ → FFT → Adaptive Energy Det\n→ Band Presence Alert"]
            YAGI_PATH["Yagi Path:\nIQ → DC Remove → Welch PSD\n→ CA-CFAR → Feature Extract\n→ RemoteID / DroneID Decode"]
        end
        subgraph CONTROL["Tracking & Control"]
            RSSI["RSSI Computation\n1024-sample window"]
            HILLCLIMB["Hill-Climbing Algorithm\nGradient: ΔR/Δθ\nV = Kp × ΔR/Δθ\nVmax = 10°/s"]
            STATE["Antenna State Machine\nIdle → Scan → Cue → Track"]
        end
        DATA["Data Layer\nSQLite | Raw IQ | JSON Logs"]
    end

    subgraph UI["Radar App (Frontend)"]
        PPI["PPI Radar Display"]
        SPEC["Spectrum Waterfall"]
        LOG["Detection Log / Alerts"]
    end

    OMNI --> BPF_A --> RXA --> OMNI_PATH
    YAGI --> BPF_B --> RXB --> YAGI_PATH
    OMNI_PATH --> STATE
    YAGI_PATH --> RSSI
    RSSI --> HILLCLIMB
    HILLCLIMB --> STATE
    STATE -->|"Velocity Cmds\n(RS-422)"| RS422
    RS422 --> SPS
    ENCODER -->|"Position\nFeedback"| STATE
    STATE --> DATA
    DATA -->|WebSocket| UI
